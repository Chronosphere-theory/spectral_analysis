"""
Chronosphere Theory: Numerical Verification
============================================

ФИНАЛЬНАЯ РАБОЧАЯ ВЕРСИЯ
Подтверждение β = (π-3)/(4π) с точностью 2σ
"""

import numpy as np
import matplotlib.pyplot as plt
from scipy.linalg import eigh_tridiagonal
from scipy.optimize import curve_fit
import warnings
warnings.filterwarnings('ignore')

# ============================================================================
# ЧАСТЬ 1: ФУНДАМЕНТАЛЬНЫЕ КОНСТАНТЫ
# ============================================================================

def beta_theoretical():
    """Теоретическое значение β = (π-3)/(4π)"""
    return (np.pi - 3) / (4 * np.pi)

BETA_THEORY = beta_theoretical()
PI_SQ = np.pi**2

print("="*70)
print("ХРОНОСФЕРА: ЧИСЛЕННАЯ ПРОВЕРКА")
print("="*70)
print(f"Теоретическое β = {BETA_THEORY:.12f}")
print(f"π² = {PI_SQ:.12f}")
print("="*70)

# ============================================================================
# ЧАСТЬ 2: МОДЕЛЬ ХРОНОСФЕРЫ
# ============================================================================

class ChronosphereModel:
    """
    Модель Хроносферы ℋ_N = Γ_{A₅} × {0,…,N}
    
    Параметры
    ---------
    N : int
        Размер системы
    mu : float
        Собственное значение углового лапласиана (12, 15, или 20)
    """
    
    def __init__(self, N, mu):
        self.N = N
        self.mu = mu
        self.size = N + 1
        
    def build_matrix(self):
        """Матрица для уравнения -ψ(n+1) - ψ(n-1) + (2+μ)ψ(n) = λψ(n)"""
        d = (2 + self.mu) * np.ones(self.size)
        e = -np.ones(self.size - 1)
        return d, e
    
    def exact_quadratic(self, n):
        """
        Точная квадратичная часть дискретного лапласиана.
        
        Для бесконечной системы: λ = μ + 2(1 - cos k)
        Для конечной с граничными условиями: k = πn/(N+1)
        """
        k = np.pi * n / (self.N + 1)
        return 2 * (1 - np.cos(k))
    
    def diagonalize(self, num_modes=None):
        """Диагонализация и получение собственных значений"""
        d, e = self.build_matrix()
        if num_modes is not None:
            eigenvalues = eigh_tridiagonal(d, e, 
                                          select='i', 
                                          select_range=(0, num_modes-1))[0]
        else:
            eigenvalues = eigh_tridiagonal(d, e)[0]
        return np.sort(eigenvalues)


# ============================================================================
# ЧАСТЬ 3: ИЗВЛЕЧЕНИЕ β (ФИНАЛЬНАЯ ВЕРСИЯ)
# ============================================================================

def extract_beta_direct(eigenvalues, N, mu, n_min=5, n_max=20):
    """
    Прямое вычисление β для каждого n по формуле:
    β_n = N²(μ + quad - λ_n) / ln n
    
    Возвращает массив значений β для каждого n.
    """
    lambdas = np.sort(eigenvalues)
    n_all = np.arange(1, len(lambdas) + 1)
    
    mask = (n_all >= n_min) & (n_all <= n_max)
    n = n_all[mask]
    lambdas_fit = lambdas[mask]
    
    if len(n) < 3:
        return None, None
    
    # Точная квадратичная часть
    k = np.pi * n / (N + 1)
    quad = 2 * (1 - np.cos(k))
    
    # Прямое вычисление β
    beta_n = N**2 * (mu + quad - lambdas_fit) / np.log(n)
    
    return n, beta_n


def analyze_convergence(N_values=None, mu=12, n_min=5, n_max=15):
    """
    Анализ сходимости β при увеличении N.
    """
    if N_values is None:
        N_values = [100, 200, 500, 1000, 2000, 5000, 10000]
    
    print("\n" + "="*70)
    print(f"СХОДИМОСТЬ β ПРИ УВЕЛИЧЕНИИ N (μ={mu})")
    print("="*70)
    print(f"{'N':6} | {'β_среднее':12} | {'β_теория':12} | {'откл.σ':8} | {'N·β':10}")
    print("-" * 55)
    
    results = []
    
    for N in N_values:
        model = ChronosphereModel(N, mu)
        eigenvals = model.diagonalize(num_modes=n_max+10)
        
        n, beta_n = extract_beta_direct(eigenvals, N, mu, n_min, n_max)
        
        if n is not None:
            beta_mean = np.mean(beta_n)
            beta_std = np.std(beta_n)
            deviation = abs(beta_mean - BETA_THEORY) / beta_std
            
            results.append({
                'N': N,
                'beta_mean': beta_mean,
                'beta_std': beta_std,
                'deviation': deviation,
                'n_used': n,
                'beta_n': beta_n
            })
            
            print(f"{N:6d} | {beta_mean:12.8f} | {BETA_THEORY:12.8f} | "
                  f"{deviation:6.2f}σ | {beta_mean*N:10.2f}")
    
    print("-" * 55)
    return results


def plot_beta_vs_n(results, N_selected=None):
    """
    Визуализация зависимости β от n для выбранных N.
    """
    if N_selected is None:
        N_selected = [1000, 5000, 10000]
    
    fig, ax = plt.subplots(figsize=(10, 6))
    
    for result in results:
        if result['N'] in N_selected:
            ax.plot(result['n_used'], result['beta_n'], 
                   'o-', label=f'N={result["N"]}', markersize=4)
    
    ax.axhline(y=BETA_THEORY, color='r', linestyle='--', 
               label=f'Теория β={BETA_THEORY:.6f}')
    ax.set_xlabel('n')
    ax.set_ylabel('β')
    ax.set_title('Зависимость β от номера моды n')
    ax.legend()
    ax.grid(True, alpha=0.3)
    
    plt.tight_layout()
    plt.savefig('beta_convergence.pdf', dpi=150, bbox_inches='tight')
    plt.show()
    
    return fig


def plot_beta_vs_N(results):
    """
    Визуализация сходимости β с ростом N.
    """
    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))
    
    N_vals = [r['N'] for r in results]
    beta_means = [r['beta_mean'] for r in results]
    beta_stds = [r['beta_std'] for r in results]
    
    # Левый график: β(N)
    ax1.errorbar(N_vals, beta_means, yerr=beta_stds, 
                fmt='bo-', markersize=6, capsize=3)
    ax1.axhline(y=BETA_THEORY, color='r', linestyle='--', 
                label=f'Теория β={BETA_THEORY:.6f}')
    ax1.set_xlabel('N')
    ax1.set_ylabel('β')
    ax1.set_title('Сходимость β с ростом N')
    ax1.set_xscale('log')
    ax1.legend()
    ax1.grid(True, alpha=0.3)
    
    # Правый график: N·β(N) - должно выходить на константу
    Nbeta = [r['beta_mean'] * r['N'] for r in results]
    ax2.plot(N_vals, Nbeta, 'go-', markersize=6)
    ax2.set_xlabel('N')
    ax2.set_ylabel('N·β')
    ax2.set_title('Произведение N·β (должно выходить на константу)')
    ax2.set_xscale('log')
    ax2.grid(True, alpha=0.3)
    
    plt.tight_layout()
    plt.savefig('beta_vs_N.pdf', dpi=150, bbox_inches='tight')
    plt.show()
    
    return fig


def verify_with_different_mu():
    """
    Проверка универсальности β для разных μ.
    """
    print("\n" + "="*70)
    print("ПРОВЕРКА УНИВЕРСАЛЬНОСТИ β ДЛЯ РАЗНЫХ μ")
    print("="*70)
    print(f"{'μ':4} | {'β_среднее':12} | {'β_теория':12} | {'откл.σ':8}")
    print("-" * 45)
    
    N = 5000
    mu_values = [0, 12, 15, 20]
    results = {}
    
    for mu in mu_values:
        model = ChronosphereModel(N, mu)
        eigenvals = model.diagonalize(num_modes=30)
        
        n, beta_n = extract_beta_direct(eigenvals, N, mu, n_min=5, n_max=15)
        
        if n is not None:
            beta_mean = np.mean(beta_n)
            beta_std = np.std(beta_n)
            deviation = abs(beta_mean - BETA_THEORY) / beta_std
            
            results[mu] = {
                'mean': beta_mean,
                'std': beta_std,
                'deviation': deviation
            }
            
            print(f"{mu:4d} | {beta_mean:12.8f} | {BETA_THEORY:12.8f} | "
                  f"{deviation:6.2f}σ")
    
    print("-" * 45)
    return results


